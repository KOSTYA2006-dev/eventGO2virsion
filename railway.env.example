# Пример переменных окружения для Railway с MySQL
# Скопируйте эти переменные в настройки вашего Web Service в Railway

# Основные настройки приложения
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:ваш-сгенерированный-ключ
# ВАЖНО: Установите APP_URL с HTTPS! Это исправит проблему Mixed Content
APP_URL=https://ваш-домен.railway.app

# Настройки базы данных MySQL (Railway автоматически создаст эти переменные)
DB_CONNECTION=mysql
DB_HOST=${{RAILWAY_PRIVATE_DOMAIN}}
DB_PORT=3306
DB_DATABASE=${{MYSQL_DATABASE}}
DB_USERNAME=root
DB_PASSWORD=${{MYSQL_ROOT_PASSWORD}}

# Альтернативный вариант (если Railway предоставляет переменные через MySQL сервис):
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Настройки почты
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ваш-email@gmail.com
MAIL_PASSWORD=ваш-пароль-приложения
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@eventgo.ru
MAIL_FROM_NAME="EventGo"

# Настройки платежей ВТБ
VTB_ACCOUNT=40702810100000000000
VTB_BIK=044525187
VTB_INN=7702070139
VTB_KPP=770201001
RECIPIENT_NAME="ООО Мероприятие"

# Дата мероприятия
EVENT_DATE=2025-12-31 18:00:00

# Настройки сессий и кеша (опционально, для production)
SESSION_DRIVER=database
CACHE_DRIVER=database
QUEUE_CONNECTION=database

